{
  "manifest_version": 3,
  "name": "scrbd - YouTube Transcripts",
  "version": "0.1.0",
  "description": "Extract YouTube video transcripts instantly. Search, copy, and download in 5 formats. No API key needed.",
  "permissions": ["activeTab"],
  "host_permissions": ["https://www.youtube.com/*"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "dist/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "default_title": "scrbd - View Transcript"
  },
  "web_accessible_resources": [
    {
      "resources": ["dist/inject.js"],
      "matches": ["https://www.youtube.com/*"]
    }
  ]
}
